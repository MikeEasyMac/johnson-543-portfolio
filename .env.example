# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
# Database name used: portfolio
# Collections: contact_messages, articles
MONGODB_URI=your_mongodb_connection_string_here

# Resend API key — obtain from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# The email address that receives contact form notifications
CONTACT_TO_EMAIL=your_email_here

# The sender address shown on outgoing emails.
# onboarding@resend.dev is accepted for testing without a verified domain.
# For production, verify your domain in the Resend dashboard and use
# a matching address (e.g. "Portfolio Contact <hello@yourdomain.com>").
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
